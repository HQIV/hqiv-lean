+    (hth : 1 < threshold) :
+    ∃ f : FanoVertex,
+      next_lattice_prime current_m h φ t β_cum threshold hδ hden hth % 7 = f.val :=
+  exists_fano_vertex_same_residue_mod_seven (next_lattice_prime current_m h φ t β_cum threshold hδ hden hth)
