+def shellCombinatoricWays_R2 (m : ℕ) : ℕ := shellCombinatoricWays 2 m
+def shellCombinatoricWays_R3 (m : ℕ) : ℕ := shellCombinatoricWays 3 m
+def shellCombinatoricWays_R4 (m : ℕ) : ℕ := shellCombinatoricWays 4 m
