+    refine ⟨(negativeActiveShells M).min' hne, ?_⟩
+    dsimp [smallestNegativeShell]
+    simp [hne]
+  rcases smallestNegativeShell_spec hsm with ⟨hm, hmin⟩
+  obtain ⟨k, hk_early, hk_neg⟩ := exists_early_negative_shell M hpos
