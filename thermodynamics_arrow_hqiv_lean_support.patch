+      simp [shellCombinatoricWays_R3, shellCombinatoricWays, n, Nat.choose_two_right]
+    _ = n * (n - 1) := hcancel
+    _ = Hqiv.latticeSimplexCount m := by
+      simp [Hqiv.latticeSimplexCount, n]
