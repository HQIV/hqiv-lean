+theorem lambdaHQIV_eq_zero_of_boundary_hyp (B : TempLadderForcesLambdaHQIVZero) :
+    B.data.conservedRedistribution → B.data.regularizedBoundary → B.lambdaHQIV = 0 :=
+  B.lambdaHQIV_eq_zero
