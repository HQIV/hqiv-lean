+theorem next_lattice_prime_same_Fano_residue_class (current_m : ℕ) (h : GlobalDetuningHypothesis)
+    (φ t β_cum : ℝ) (threshold : ℝ) (hδ : 0 ≤ delta_auxiliary_phi_per_shell h φ t β_cum)
