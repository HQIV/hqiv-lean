+    2 * shellCombinatoricWays_R3 m = Hqiv.latticeSimplexCount m := by
+  let n := m + 2
+  have hdvd : 2 ∣ n * (n - 1) := even_iff_two_dvd.mp (Nat.even_mul_pred_self n)
+  have hcancel : (n * (n - 1)) / 2 * 2 = n * (n - 1) := by
