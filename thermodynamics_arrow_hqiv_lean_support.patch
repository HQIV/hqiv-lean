+/-- Vertex chosen for insertion on shell `m`. -/
+noncomputable def openingVertex (M : Discrete3Complex NullShellVertex) (m : ℕ)
+    (h : negativeBudget M m) : NullShellVertex :=
+  ⟨m, minUnusedTagAtShell M m h⟩
