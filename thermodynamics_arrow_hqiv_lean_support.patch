+        (mem_negativeActiveShells.mp (Finset.min'_mem _ hs)).1)
+        (minUnusedTag_vertex_not_mem M _ _) hV) ≤ lyapunovFunctional M := by
+      simp only [lyapunovFunctional_eq_shell0_budget]
