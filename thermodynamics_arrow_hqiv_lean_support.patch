+/-- Concrete finite-window witness with explicit `Finset.range N` equalities. -/
+structure TempLadderFiniteWindowConcrete where
+  N : ℕ
+  T_ref : ℝ
+  shellWeight : ℕ → ℝ
+  deltaEslot : ℕ → ℝ
+  phi_t_from_ladder : ℕ → ℝ
+  hT_nonzero : T_ref ≠ 0
