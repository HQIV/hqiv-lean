open Matrix

namespace Hqiv.Algebra

abbrev GaugeMatrix := Matrix (Fin 8) (Fin 8) ℝ

set_option maxHeartbeats 800000000

/-- Upper-triangle index in lexicographic order `(0,1), (0,2), ... , (6,7)`. -/
def upperTriangleIdx (p : Fin 28) : Fin 8 × Fin 8 :=
  if p.val = 0 then ((0 : Fin 8), (1 : Fin 8))
  else if p.val = 1 then ((0 : Fin 8), (2 : Fin 8))
  else if p.val = 2 then ((0 : Fin 8), (3 : Fin 8))
  else if p.val = 3 then ((0 : Fin 8), (4 : Fin 8))
  else if p.val = 4 then ((0 : Fin 8), (5 : Fin 8))
  else if p.val = 5 then ((0 : Fin 8), (6 : Fin 8))
  else if p.val = 6 then ((0 : Fin 8), (7 : Fin 8))
  else if p.val = 7 then ((1 : Fin 8), (2 : Fin 8))
  else if p.val = 8 then ((1 : Fin 8), (3 : Fin 8))
  else if p.val = 9 then ((1 : Fin 8), (4 : Fin 8))
  else if p.val = 10 then ((1 : Fin 8), (5 : Fin 8))
  else if p.val = 11 then ((1 : Fin 8), (6 : Fin 8))
  else if p.val = 12 then ((1 : Fin 8), (7 : Fin 8))
  else if p.val = 13 then ((2 : Fin 8), (3 : Fin 8))
  else if p.val = 14 then ((2 : Fin 8), (4 : Fin 8))
  else if p.val = 15 then ((2 : Fin 8), (5 : Fin 8))
  else if p.val = 16 then ((2 : Fin 8), (6 : Fin 8))
  else if p.val = 17 then ((2 : Fin 8), (7 : Fin 8))
  else if p.val = 18 then ((3 : Fin 8), (4 : Fin 8))
  else if p.val = 19 then ((3 : Fin 8), (5 : Fin 8))
  else if p.val = 20 then ((3 : Fin 8), (6 : Fin 8))
  else if p.val = 21 then ((3 : Fin 8), (7 : Fin 8))
  else if p.val = 22 then ((4 : Fin 8), (5 : Fin 8))
  else if p.val = 23 then ((4 : Fin 8), (6 : Fin 8))
  else if p.val = 24 then ((4 : Fin 8), (7 : Fin 8))
  else if p.val = 25 then ((5 : Fin 8), (6 : Fin 8))
  else if p.val = 26 then ((5 : Fin 8), (7 : Fin 8))
  else ((6 : Fin 8), (7 : Fin 8))

/-- Extract the upper-triangle coordinate matching `upperTriangleIdx`. -/
def coordVec (M : GaugeMatrix) (p : Fin 28) : ℝ :=
  M (upperTriangleIdx p).1 (upperTriangleIdx p).2

/-- The explicit G₂ seed set inside the 8×8 matrix carrier. -/
def G2Generators : Set GaugeMatrix :=
  Set.range g2Generator

/-- The physical HQIV generating set: the 14 G₂ derivation generators together with `Δ`. -/
def G2UnionDelta : Set GaugeMatrix :=
  G2Generators ∪ {Hqiv.phaseLiftDelta}

/-- The standard Euclidean `so(8)` model inside 8×8 matrices. -/
def so8LieSubalgebra : LieSubalgebra ℝ GaugeMatrix :=
  skewAdjointMatricesLieSubalgebra (1 : GaugeMatrix)

lemma mem_so8LieSubalgebra_iff (M : GaugeMatrix) :
    M ∈ so8LieSubalgebra ↔ Mᵀ = -M := by
  rw [so8LieSubalgebra, mem_skewAdjointMatricesLieSubalgebra, mem_skewAdjointMatricesSubmodule]
  simp [Matrix.IsSkewAdjoint, Matrix.IsAdjointPair]

theorem g2Generator_mem_so8LieSubalgebra (k : Fin 14) :
    g2Generator k ∈ so8LieSubalgebra := by
  rw [mem_so8LieSubalgebra_iff]
  exact eq_neg_iff_add_eq_zero.mpr (by simpa [add_comm] using g2_in_so8 k)

theorem phaseLiftDelta_mem_so8LieSubalgebra :
    Hqiv.phaseLiftDelta ∈ so8LieSubalgebra := by
  rw [mem_so8LieSubalgebra_iff]
  exact eq_neg_iff_add_eq_zero.mpr (by simpa [add_comm] using phaseLiftDelta_antisymm)

theorem G2UnionDelta_subset_so8LieSubalgebra :
    G2UnionDelta ⊆ so8LieSubalgebra := by
  intro M hM
  rcases hM with (⟨k, rfl⟩ | rfl)
  · exact g2Generator_mem_so8LieSubalgebra k
  · exact phaseLiftDelta_mem_so8LieSubalgebra

/-- The Lie subalgebra generated by the physical seed set `G₂ ∪ {Δ}`. -/
def g2DeltaGeneratedLie : LieSubalgebra ℝ GaugeMatrix :=
  LieSubalgebra.lieSpan ℝ GaugeMatrix G2UnionDelta

theorem G2UnionDelta_subset_g2DeltaGeneratedLie :
    G2UnionDelta ⊆ g2DeltaGeneratedLie := by
  simpa [g2DeltaGeneratedLie] using
    (LieSubalgebra.subset_lieSpan (R := ℝ) (L := GaugeMatrix) (s := G2UnionDelta))

theorem g2Generator_mem_g2DeltaGeneratedLie (k : Fin 14) :
    g2Generator k ∈ g2DeltaGeneratedLie := by
  exact G2UnionDelta_subset_g2DeltaGeneratedLie (Or.inl ⟨k, rfl⟩)

theorem phaseLiftDelta_mem_g2DeltaGeneratedLie :
    Hqiv.phaseLiftDelta ∈ g2DeltaGeneratedLie := by
  exact G2UnionDelta_subset_g2DeltaGeneratedLie (Or.inr rfl)

theorem span_G2UnionDelta_le_g2DeltaGeneratedLie :
    Submodule.span ℝ G2UnionDelta ≤ (g2DeltaGeneratedLie : Submodule ℝ GaugeMatrix) := by
  simpa [g2DeltaGeneratedLie] using
    (LieSubalgebra.submodule_span_le_lieSpan (R := ℝ) (L := GaugeMatrix) (s := G2UnionDelta))

theorem g2DeltaGeneratedLie_le_iff {K : LieSubalgebra ℝ GaugeMatrix} :
    g2DeltaGeneratedLie ≤ K ↔ G2UnionDelta ⊆ K := by
  simpa [g2DeltaGeneratedLie] using
    (LieSubalgebra.lieSpan_le (R := ℝ) (L := GaugeMatrix) (s := G2UnionDelta) (K := K))

theorem g2DeltaGeneratedLie_le_so8LieSubalgebra :
    g2DeltaGeneratedLie ≤ so8LieSubalgebra := by
  rw [g2DeltaGeneratedLie_le_iff]
  exact G2UnionDelta_subset_so8LieSubalgebra

/-- The 15 physical seeds: the 14 `G₂` generators plus `Δ`. -/
def g2DeltaSeed (idx : Fin 15) : GaugeMatrix :=
  match idx.val with
  | 0 => g2Generator 0
  | 1 => g2Generator 1
  | 2 => g2Generator 2
  | 3 => g2Generator 3
  | 4 => g2Generator 4
  | 5 => g2Generator 5
  | 6 => g2Generator 6
  | 7 => g2Generator 7
  | 8 => g2Generator 8
  | 9 => g2Generator 9
  | 10 => g2Generator 10
  | 11 => g2Generator 11
  | 12 => g2Generator 12
  | 13 => g2Generator 13
  | 14 => Hqiv.phaseLiftDelta
  | _ => Hqiv.phaseLiftDelta

theorem g2DeltaSeed_mem_g2DeltaGeneratedLie (idx : Fin 15) :
    g2DeltaSeed idx ∈ g2DeltaGeneratedLie := by
  fin_cases idx
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 0
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 1
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 2
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 3
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 4
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 5
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 6
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 7
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 8
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 9
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 10
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 11
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 12
  · simpa [g2DeltaSeed] using g2Generator_mem_g2DeltaGeneratedLie 13
  · simpa [g2DeltaSeed] using phaseLiftDelta_mem_g2DeltaGeneratedLie

/--
An explicit 28-element witness family inside the generated Lie algebra.
It consists of 14 seeds (`G₂` except one redundant seed, plus `Δ`) and 14 seed-seed brackets.
-/
def g2DeltaWitness (idx : Fin 28) : GaugeMatrix :=
  match idx.val with
  | 0 => g2DeltaSeed 0
  | 1 => g2DeltaSeed 1
  | 2 => g2DeltaSeed 2
  | 3 => g2DeltaSeed 3
  | 4 => g2DeltaSeed 4
  | 5 => g2DeltaSeed 5
  | 6 => g2DeltaSeed 7
  | 7 => g2DeltaSeed 8
  | 8 => g2DeltaSeed 9
  | 9 => g2DeltaSeed 10
  | 10 => g2DeltaSeed 11
  | 11 => g2DeltaSeed 12
  | 12 => g2DeltaSeed 13
  | 13 => g2DeltaSeed 14
  | 14 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 3)
  | 15 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 4)
  | 16 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 8)
  | 17 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 9)
  | 18 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 11)
  | 19 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 12)
  | 20 => Hqiv.lieBracket (g2DeltaSeed 0) (g2DeltaSeed 13)
  | 21 => Hqiv.lieBracket (g2DeltaSeed 1) (g2DeltaSeed 2)
  | 22 => Hqiv.lieBracket (g2DeltaSeed 1) (g2DeltaSeed 3)
  | 23 => Hqiv.lieBracket (g2DeltaSeed 1) (g2DeltaSeed 4)
  | 24 => Hqiv.lieBracket (g2DeltaSeed 1) (g2DeltaSeed 8)
  | 25 => Hqiv.lieBracket (g2DeltaSeed 1) (g2DeltaSeed 9)
  | 26 => Hqiv.lieBracket (g2DeltaSeed 1) (g2DeltaSeed 13)
  | 27 => Hqiv.lieBracket (g2DeltaSeed 2) (g2DeltaSeed 3)
  | _ => Hqiv.lieBracket (g2DeltaSeed 2) (g2DeltaSeed 3)

