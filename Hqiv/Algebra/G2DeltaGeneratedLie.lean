    g2DeltaWitness idx ∈ g2DeltaGeneratedLie := by
  fin_cases idx
  · simpa [g2DeltaWitness] using g2DeltaSeed_mem_g2DeltaGeneratedLie 0
  · simpa [g2DeltaWitness] using g2DeltaSeed_mem_g2DeltaGeneratedLie 1
  · simpa [g2DeltaWitness] using g2DeltaSeed_mem_g2DeltaGeneratedLie 2
  · simpa [g2DeltaWitness] using g2DeltaSeed_mem_g2DeltaGeneratedLie 3
