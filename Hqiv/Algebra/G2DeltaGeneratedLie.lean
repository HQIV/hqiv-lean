  ·
    simpa [g2DeltaWitness] using
      (LieSubalgebra.lie_mem g2DeltaGeneratedLie
        (g2DeltaSeed_mem_g2DeltaGeneratedLie 0)
        (g2DeltaSeed_mem_g2DeltaGeneratedLie 3))
  ·
    simpa [g2DeltaWitness] using
